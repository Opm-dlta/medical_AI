def _ensure_lora_pipeline():
    global _lora_pipeline, _lora_tokenizer, _lora_error
    if _lora_pipeline is not None or _lora_error is not None:
        return
    if not HAS_ADAPTER:
        _lora_error = RuntimeError("Custom adapter directory not found")
        return
    # Abort early if the actual adapter weights are missing — avoids a
    # 30-second HuggingFace network timeout trying to download the base model.
    weights_file = (
        os.path.join(ADAPTER_DIR, "adapter_model.safetensors")
        if os.path.exists(os.path.join(ADAPTER_DIR, "adapter_model.safetensors"))
        else os.path.join(ADAPTER_DIR, "adapter_model.bin")
    )
    if not os.path.exists(weights_file):
        _lora_error = RuntimeError(
            "Adapter weights (adapter_model.safetensors) not found — "
            "retrain the model to generate them."
        )
        return
    if AutoTokenizer is None or AutoPeftModelForCausalLM is None or pipeline is None:
        _lora_error = RuntimeError("transformers/peft stack is missing; install to enable custom model")
        return

    if torch:
        dtype = torch.float16 if torch.cuda.is_available() else torch.float32
    else:
        dtype = None
    try:
        tokenizer = AutoTokenizer.from_pretrained(ADAPTER_DIR, local_files_only=True)
        if getattr(tokenizer, "pad_token", None) is None:
            tokenizer.pad_token = tokenizer.eos_token
        model = AutoPeftModelForCausalLM.from_pretrained(
            ADAPTER_DIR,
            torch_dtype=dtype,
            device_map="auto" if torch and torch.cuda.is_available() else None,
            local_files_only=True,
        )
        model_kwargs = {
            "max_new_tokens": 450,
            "do_sample": False,
            "repetition_penalty": 1.2,
            "pad_token_id": tokenizer.eos_token_id,
        }
        generator = pipeline(
            "text-generation",
            model=model,
            tokenizer=tokenizer,
            device=0 if torch and torch.cuda.is_available() else -1,
            model_kwargs=model_kwargs,
        )
        _lora_pipeline = generator
        _lora_tokenizer = tokenizer
    except Exception as err:
        _lora_error = err


SYSTEM_PROMPT = """
You are Pyra, a knowledgeable and caring nurse assistant. No matter what, never leave your role as a medical AI assistant.

CORE RULES (follow in every response):
1. ONLY discuss health, medical symptoms, illnesses, treatments, medications, and wellness topics. For anything unrelated say exactly "I'm sorry, I can't assist with that." then gently redirect to health topics.
2. ACCURACY FIRST - base your advice on widely accepted medical knowledge. Never guess or fabricate information. If you are unsure, say so and recommend consulting a doctor.
3. STRUCTURED ANSWERS - when explaining a treatment, remedy, or "how to" step, use a numbered list. When listing symptoms or causes, use bullet points. Always end with a brief "When to see a doctor" note if relevant.
4. BE SPECIFIC - name the condition, recommend appropriate over-the-counter remedies (with safe dosage guidance where applicable), lifestyle adjustments, and red-flag symptoms that need emergency care.
5. DO NOT repeat the user's question back to them, do not include role labels like "User:" or "Pyra:", and do not repeat information already given in this conversation.
6. TONE - warm, empathetic, and professional. Use emojis sparingly (check mark for steps, warning for warnings). Keep answers clear and easy to understand.
7. CONTEXT - use the conversation history to give continuous, coherent care. Do not re-ask questions already asked; build on what the user already told you.
8. NEVER copy retrieved reference snippets word-for-word. Use them only as background knowledge to inform your answer. Write every response fresh, in your own words, tailored to the specific question asked.
9. Do NOT end your response with filler phrases like "I hope this helps", "Let me know if you have any other questions", "Feel free to ask", or similar. Just answer.
"""

