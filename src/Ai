def find_relevant_example(user_question):
    for item in train_data:
        try:
            if user_question.lower() in item.get("prompt", "").lower():
                return item.get("response", "")
        except Exception:
            continue
    return ""


def _normalize(text: str):
    t = (text or "").lower()
    t = re.sub(r"[^a-z0-9\s]", " ", t)
    return [w for w in t.split() if w]


def retrieve_snippets(user_question: str, k: int = 5, max_chars: int = 1600) -> str:
    """Return the top-k most relevant training snippets using Jaccard similarity.

    Jaccard = |intersection| / |union| penalises verbose documents that happen
    to share a few common words, surfacing concise, on-topic matches instead.
    """
    if not train_data:
        return ""
    q_tokens = set(_normalize(user_question))
    if not q_tokens:
        return ""
    scored = []
    for item in train_data:
        try:
            prompt_toks = set(_normalize(item.get("prompt", "")))
            resp_toks = set(_normalize(item.get("response", "")))
            doc_toks = prompt_toks | resp_toks
            if not doc_toks:
                continue
            intersection = q_tokens & doc_toks
            if not intersection:
                continue
            # Jaccard similarity (higher = better match)
            jaccard = len(intersection) / len(q_tokens | doc_toks)
            # Prefer items whose *prompt* matches (question-level relevance)
            prompt_bonus = len(q_tokens & prompt_toks) / max(len(q_tokens), 1)
            score = jaccard + 0.5 * prompt_bonus
            # Only pass the *response* to the model — avoids echoing the training question back
            body = item.get("response", "").strip()
            scored.append((score, body))
        except Exception:
            continue
    if not scored:
        return ""
    scored.sort(key=lambda x: x[0], reverse=True)
    lines = []
    total = 0
    for _, body in scored[:k]:
        snippet = body.replace("\r", " ").replace("\n", " ")
        snippet = snippet[:400].strip()
        if snippet:
            line = f"- {snippet}"
            if total + len(line) + (1 if lines else 0) > max_chars:
                break
            lines.append(line)
            total += len(line) + (1 if lines else 0)
    return "\n".join(lines)


def _is_medical(text: str) -> bool:
    tokens = set(_normalize(text))
    return any(tok in _MEDICAL_KEYWORDS for tok in tokens)

