_REFUSAL = (
    "I'm sorry, I can't assist with that. 😊 "
    "I'm Pyra, your medical assistant — I'm here to help with health questions, "
    "symptoms, medications, and general wellness. "
    "Is there anything health-related I can help you with today?"
)


def _guard_topic(user_question: str, history=None) -> str | None:
    """Return a refusal string if the question is clearly non-medical, else None.

    Only the explicit _OFF_TOPIC_PATTERNS are hard-blocked — keyword absence alone
    is NOT enough to block, because typos ("diareah"), follow-up questions
    ("is it normal if it looks yellow?") and symptom descriptions in plain language
    all fail keyword matching while being completely legitimate medical queries.
    The system prompt handles anything borderline that reaches the LLM.
    """
    text = user_question.strip()
    if not text:
        return None
    # Always allow follow-ups when there is an active medical conversation
    if history:
        for _, bot in reversed((history or [])[-3:]):
            if bot and _is_medical(bot):
                return None
  # Hard block: explicit off-topic patterns only  
    if _OFF_TOPIC_PATTERNS.search(text):
        return _REFUSAL
    return None


def _recent_history(history, limit=MAX_CONTEXT_TURNS):
    if not history or limit <= 0:
        return []
    return history[-limit:]


def _select_relevant_history(history, user_question):
    recent = _recent_history(history)
    if not recent:
        return []
    # Always keep the most recent turn regardless of topic — the user may be
    # asking a follow-up that has no medical keywords but still depends on it
    # (e.g. "how long does it last?" after "I have a headache").
    last_turn = recent[-1:]
    if not _is_medical(user_question):
        return recent
    medical_only = [pair for pair in recent if pair and _is_medical(pair[0] or "")]
    if not medical_only:
        return last_turn
    # Ensure the very last turn is always present even if non-medical
    if recent[-1] not in medical_only:
        medical_only = medical_only + last_turn
    return medical_only


def _build_chat_messages(user_question: str, history, retrieved: str):
    messages = [{"role": "system", "content": SYSTEM_PROMPT.strip()}]
    for user, bot in _select_relevant_history(history, user_question):
        if user:
            messages.append({"role": "user", "content": str(user)})
        if bot:
            messages.append({"role": "assistant", "content": str(bot)})

    content = user_question.strip()
    if retrieved:
        content += f"\n\nRetrieved context:\n{retrieved}"
    messages.append({"role": "user", "content": content})
    return messages


def _truncate_at_next_turn(text: str) -> str:
    """Cut off only when the model starts simulating a full dialogue exchange.

    Requires a blank line before the role label so single-newline prose like
    'For the patient: rest...' or 'Question: should you...' is never truncated.
    Only 'user:' and 'human:' are matched — 'patient', 'question' and 'you'
    appear too often in legitimate medical advice to be safe triggers.
    """
    m = re.search(r"\n{2,}(?:user|human)\s*:", text, re.IGNORECASE)
    if m:
        return text[: m.start()].strip()
    return text


def _strip_question_echo(text: str, user_question: str) -> str:
    """Remove the user's question if the model echoed it at the start of its reply."""
    if not text or not user_question:
        return text
    # Normalise both to lowercase for comparison
    norm_reply = text.lower().lstrip()
    norm_q = user_question.lower().strip()
    # Check first 60 chars of the reply against first 60 chars of the question
    if norm_reply[: min(60, len(norm_q))].startswith(norm_q[: min(60, len(norm_q))]):
        return text[len(norm_q) :].lstrip(" :.\\-\n")
    return text


def sanitize_bot_text(text: str) -> str:
    if not text:
        return ""
    pattern = re.compile(
        r"^\s*(?:\*\*|\*|_|`|\(|\[)?\s*(pyra|assistant|bot)\s*(?:\*\*|\*|_|`|\)|\])?\s*[:\-–—]\s*",
        re.IGNORECASE,
    )
    prev = None
    while prev != text:
        prev = text
        text = pattern.sub("", text)
    return text


def _dedupe_paragraphs(text: str) -> str:
    paragraphs = [p.strip() for p in re.split(r"\n{2,}", text) if p.strip()]
    seen = set()
    ordered = []
    for para in paragraphs:
        key = para.lower()
        if key in seen:
            continue
        seen.add(key)
        ordered.append(para)
    if not ordered:
        return text.strip()
    if len(ordered) == len(paragraphs):
        sentences = [s.strip() for s in re.split(r"(?<=[.!?])\s+", text) if s.strip()]
        seen_sent = set()
        filtered = []
        for sentence in sentences:
            key = sentence.lower()
            if key in seen_sent:
                continue
            seen_sent.add(key)
            filtered.append(sentence)
        return " ".join(filtered)
    return "\n\n".join(ordered)


_FILLER_TAIL = re.compile(
    r"[\s,\.]*"
    r"(?:i hope this (?:helps|answers|was helpful)[^.!?]*[.!?]?"
    r"|let me know (?:if you have|should you have)[^.!?]*[.!?]?"
    r"|feel free to (?:ask|reach out)[^.!?]*[.!?]?"
    r"|don'?t hesitate to (?:ask|reach out)[^.!?]*[.!?]?"
    r"|please (?:consult|see|visit) (?:a|your)[^.!?]*[.!?]?"
    r"|if you (?:have|need) (?:any )?(?:more|further|additional) (?:questions?|concerns?|help)[^.!?]*[.!?]?"
    r")"
    r"[\s😊🙂]*$",
    re.IGNORECASE,
)


def _strip_filler_tail(text: str) -> str:
    """Remove training-data closing filler phrases and trailing emojis."""
    prev = None
    while prev != text:
        prev = text
        text = _FILLER_TAIL.sub("", text).rstrip()
    # Strip any stray trailing emojis left after filler removal
    text = re.sub(r"[\s😊🙂😃😄🤗]+$", "", text).rstrip()
    return text


def clean_model_reply(text: str, user_question: str = "") -> str:
    t = (text or "")
    # Strip next-turn simulation before anything else
    t = _truncate_at_next_turn(t)
    # Strip leading "Answer:" / "Response:" the prompt template may leak
    t = re.sub(r"^(?:answer|response)\s*:\s*", "", t, flags=re.IGNORECASE)
    if t.lstrip().lower().startswith(("user:", "you:")):
        m = re.search(r"(?i)(pyra|assistant|bot)\s*:\s*", t)
        if m:
            t = t[m.end():]
        else:
            lines = t.splitlines()
            t = "\n".join(lines[1:]) if len(lines) > 1 else ""
    t = sanitize_bot_text(t)
    # Strip question echo after role-label cleanup
    if user_question:
        t = _strip_question_echo(t, user_question)
    t = _strip_filler_tail(t)
    t = t.strip()
    return _dedupe_paragraphs(t)


def _first_sentence(text: str) -> str:
    if not text:
        return ""
    m = re.split(r"(?<=[.!?])\s+", text.strip(), maxsplit=1)
    return m[0].strip() if m else text.strip()


def remove_redundant_opening(new_text: str, history) -> str:
    if not new_text:
        return new_text
    last_bot = None
    for u, b in reversed(history or []):
        if b:
            last_bot = b
            break
    if not last_bot:
        return new_text
    s_new = _first_sentence(new_text).lower()
    s_old = _first_sentence(last_bot).lower()
    if not s_new or not s_old:
        return new_text
    prefix_len = 0
    for a, c in zip(s_new, s_old):
        if a == c:
            prefix_len += 1
        else:
            break
    if s_new == s_old or prefix_len >= 20:
        parts = re.split(r"(?<=[.!?])\s+", new_text.strip(), maxsplit=1)
        return parts[1].strip() if len(parts) > 1 else ""
    return new_text


def generate_response(user_question, history):
    global chain, _model_load_error, _lora_error

    # Hard topic gate — returns immediately without touching the model
    refusal = _guard_topic(user_question, history)
    if refusal:
        return refusal

    # Only compute RAG snippets if the fine-tuned LoRA model is available.
    # For the Ollama fallback we rely entirely on the base model's built-in
    # medical knowledge — injecting training snippets causes copy-paste echoing.
    _ensure_lora_pipeline()
    use_lora = _lora_pipeline is not None and _lora_tokenizer is not None and _lora_error is None
    retrieved = retrieve_snippets(user_question) if use_lora else ""

    if use_lora:
        messages = _build_chat_messages(user_question, history, retrieved)
        try:
            prompt_text = _lora_tokenizer.apply_chat_template(
                messages,
                tokenize=False,
                add_generation_prompt=True,
            )
            generations = _lora_pipeline(
                prompt_text,
                max_new_tokens=450,
                do_sample=False,
                repetition_penalty=1.2,
                return_full_text=False,
            )
            if generations and generations[0].get("generated_text"):
                raw = generations[0]["generated_text"].strip()
                return clean_model_reply(raw, user_question)
        except Exception as err:
            _lora_error = err

    if chain is None:
        if OllamaLLM is None or ChatPromptTemplate is None:
            message = "Custom adapter failed to load"
            if _lora_error:
                message += f": {_lora_error}"
            raise RuntimeError(message)
        try:
            # temperature=0.35 — low enough to stay on-topic, high enough to
            # generate a fresh answer rather than copying retrieved snippets.
            model = OllamaLLM(model="llama2:7b-chat-q4_K_M", temperature=0.5, num_predict=600)
            prompt = ChatPromptTemplate.from_template(OLLAMA_PROMPT_TEMPLATE)
            chain = prompt | model
        except Exception as e:
            _model_load_error = e
            raise RuntimeError(f"Model load failed: {e}")

    context = ""
    for h in _select_relevant_history(history, user_question):
        context += f"\nUser: {h[0]}\nPyra: {h[1]}"
    result = chain.invoke({"context": context, "question": user_question})
    return clean_model_reply(str(result), user_question)

